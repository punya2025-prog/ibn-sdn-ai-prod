# IBN-SDN-AI Version 2 — Environment Configuration
# Copy this to .env and update passwords before starting

# ── Gateway ───────────────────────────────────────────────────────────────
PORT=8002
HOST=0.0.0.0
GATEWAY_URL=http://192.168.20.15:8001

# ── LLM Backend ───────────────────────────────────────────────────────────
LLM_BACKEND=ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3
LLM_TIMEOUT=120

# ── RAG Configuration ─────────────────────────────────────────────────────
RAG_ENABLED=true
CHROMA_PATH=rag_db
TRANSFORMERS_OFFLINE=1
HF_HUB_OFFLINE=1

# ── ODL Controller ────────────────────────────────────────────────────────
ODL_BASE=http://localhost:8181
ODL_USER=admin
ODL_PASSWORD=admin

# ── eAPI — ContainerLab cEOS (HTTP) ──────────────────────────────────────
EAPI_USERNAME=admin
EAPI_PASSWORD=admin
EAPI_TRANSPORT=https
EAPI_PORT=443

# ── eAPI — Physical Arista 7010 (HTTPS) ──────────────────────────────────
PHYSICAL_ARISTA_HOST=192.168.20.105
PHYSICAL_ARISTA_USER=admin
PHYSICAL_ARISTA_PASS=CHANGE_ME_IN_PRODUCTION
PHYSICAL_ARISTA_PORT=443
PHYSICAL_ARISTA_TRANSPORT=https

# ── GNN ───────────────────────────────────────────────────────────────────
GNN_ENABLED=true
GNN_INTERVAL=60

# ── Approval ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
APPROVAL_TIMEOUT_HOURS=4

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
AUDIT_LOG=logs/audit.log

# ── Scoring thresholds ────────────────────────────────────────────────────
AUTO_DEPLOY_THRESHOLD=0.90
APPROVAL_THRESHOLD=0.70
